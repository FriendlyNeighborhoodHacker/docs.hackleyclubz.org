---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((entry) => {
    // The "index" file of a section maps to the section root, e.g.
    // developer-docs/index -> developer-docs
    const slug = entry.id.replace(/\/index$/, '');
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const slug = entry.id.replace(/\/index$/, '');
---

<DocsLayout title={entry.data.title} description={entry.data.description} slug={slug}>
  <Content />
</DocsLayout>
